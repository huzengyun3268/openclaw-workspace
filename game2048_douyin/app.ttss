/* 全局样式 */
page {
  background: #1a1a2e;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
}
.title {
  font-size: 40rpx;
  font-weight: bold;
  margin: 40rpx 0 20rpx;
  color: #f79711;
  letter-spacing: 6rpx;
}
.score-row {
  display: flex;
  gap: 60rpx;
  font-size: 26rpx;
  color: #aaa;
  margin-bottom: 20rpx;
}
.score-num {
  color: #f79711;
  font-size: 36rpx;
  font-weight: bold;
}
